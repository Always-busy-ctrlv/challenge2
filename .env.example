# ─── ElectEd Environment Configuration ───────────────────
# Copy this file to .env and fill in your values

# ── GCP / Firebase ───────────────────────────────────────
GCP_PROJECT_ID=elected2026app
GOOGLE_CLOUD_PROJECT=elected2026app
FIREBASE_PROJECT_ID=elected2026app

# Firebase Admin SDK — path to service account key JSON
# Download from: Firebase Console → Project Settings → Service accounts
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ── Service URLs (for local development) ─────────────────
CONTENT_SERVICE_URL=http://localhost:4001
QUIZ_SERVICE_URL=http://localhost:4002
API_GATEWAY_URL=http://localhost:8080

# ── Service Ports ────────────────────────────────────────
API_GATEWAY_PORT=8080
CONTENT_SERVICE_PORT=4001
QUIZ_SERVICE_PORT=4002

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Vertex AI (Gemini) ───────────────────────────────────
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash

# ── Cloud Run (Production) ───────────────────────────────
# K_SERVICE — auto-set by Cloud Run
# K_REVISION — auto-set by Cloud Run

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ── Firebase Client SDK (for web app) ────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=elected2026app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=elected2026app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=elected2026app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
